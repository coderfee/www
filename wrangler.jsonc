{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "blog",
  "main": "src/worker.ts",
  "compatibility_date": "2026-06-23",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "triggers": {
    "crons": ["17 1 * * *"]
  },
  "observability": {
    "enabled": true
  }
}
