{
  "name": "www",
  "type": "module",
  "version": "3.0.0",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "dev": "pnpm run sync-r2 && astro dev",
    "build": "pnpm run sync-r2 && astro build",
    "lint": "pnpm biome check ./src && astro check --minimumSeverity warning",
    "lint:fix": "pnpm biome check ./src --write",
    "upgrade": "pnpm update && pnpx @astrojs/upgrade",
    "sync-r2": "node scripts/sync-r2.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "5.0.0-beta.2",
    "@astrojs/react": "5.0.0-beta.2",
    "@astrojs/rss": "4.0.15-beta.1",
    "@astrojs/sitemap": "3.6.1-beta.2",
    "@nanostores/persistent": "^1.3.3",
    "@nanostores/react": "^1.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "6.0.0-beta.3",
    "framer-motion": "^12.34.3",
    "nanostores": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-mdx-code-props": "^3.0.1",
    "rehype-slug": "^6.0.0",
    "remark-toc": "^9.0.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.997.0",
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@iconify-json/tabler": "^1.2.27",
    "@iconify/react": "^6.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "latest",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "lefthook": "^2.1.2",
    "unplugin-icons": "^23.0.1"
  }
