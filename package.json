{
  "name": "www",
  "type": "module",
  "version": "3.0.0",
  "packageManager": "pnpm@10.29.1",
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "dev": "pnpm run sync-r2 && astro dev",
    "build": "pnpm run sync-r2 && wrangler types && astro build",
    "lint": "pnpm biome check ./src && astro check --minimumSeverity warning",
    "lint:fix": "pnpm biome check ./src --write",
    "upgrade": "pnpm update && pnpx @astrojs/upgrade",
    "sync-r2": "node scripts/sync-r2.mjs"
  },
  "dependencies": {
    "@astrojs/check": "0.9.7-beta.1",
    "@astrojs/mdx": "5.0.0-beta.5",
    "@astrojs/react": "5.0.0-beta.3",
    "@astrojs/rss": "4.0.15-beta.3",
    "@astrojs/sitemap": "3.6.1-beta.3",
    "@nanostores/persistent": "^1.3.3",
    "@nanostores/react": "^1.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "astro": "6.0.0-beta.9",
    "framer-motion": "^12.33.0",
    "nanostores": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-mdx-code-props": "^3.0.1",
    "rehype-slug": "^6.0.0",
    "remark-toc": "^9.0.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "13.0.0-beta.5",
    "@aws-sdk/client-s3": "^3.985.0",
    "@biomejs/biome": "^2.3.14",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@iconify-json/tabler": "^1.2.26",
    "@iconify/react": "^6.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "latest",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.4",
    "lefthook": "^2.1.0",
    "unplugin-icons": "^23.0.1",
    "wrangler": "^4.63.0"
