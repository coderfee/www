---
const site = Astro.site ? Astro.site.toString().replace(/\/$/, '') : '';
const theme = import.meta.env.PROD && site ? `${site}/styles/giscus.css` : 'preferred_color_scheme';
---

<section id="comments" class="mt-16 animate-in fade-in slide-in-from-bottom-8 duration-1000" aria-label="评论区">
  <div class="giscus"></div>
</section>

<script
  is:inline
  src="https://giscus.app/client.js"
  data-repo="coderfee/www"
  data-repo-id="MDEwOlJlcG9zaXRvcnkxNjA5OTc3MTY="
  data-category="Comments"
  data-category-id="DIC_kwDOCZihVM4CoBlh"
  data-mapping="pathname"
  data-strict="0"
  data-reactions-enabled="1"
  data-emit-metadata="0"
  data-input-position="top"
  data-theme={theme}
  data-lang="zh-CN"
  data-loading="lazy"
  crossorigin="anonymous"
  async
  defer
></script>
