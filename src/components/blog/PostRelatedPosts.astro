---
import { getCollection } from 'astro:content';
import dayjs from 'dayjs';
import IconArrowRight from '~icons/tabler/arrow-right';
import IconLink from '~icons/tabler/link';

interface Props {
  currentSlug: string;
  tags: string[];
  limit?: number;
}

const { currentSlug, tags, limit = 3 } = Astro.props;

const posts = await getCollection('blog');

const scoredPosts = posts
  .filter(({ data: { draft = false } }) => !draft)
  .filter((post) => post.id !== currentSlug)
  .map((post) => {
    const postTags = post.data.tags || [];
    const matchCount = postTags.filter((tag) => tags.includes(tag)).length;
    return { post, matchCount };
  })
  .filter((item) => item.matchCount > 0)
  .sort((a, b) => {
    if (a.matchCount === b.matchCount) {
      return b.post.data.date.valueOf() - a.post.data.date.valueOf();
    }
    return b.matchCount - a.matchCount;
  })
  .slice(0, limit);
---

{scoredPosts.length > 0 && (
  <aside class="my-32" aria-label="相关文章">
    <div class="mb-12">
      <h2 class="text-xs font-mono text-zinc-400 uppercase tracking-[0.3em]">Related Reads</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-20">
      {scoredPosts[0] && (
        <a 
          href={`/blog/${scoredPosts[0].post.id}`}
          class="md:col-span-2 group relative overflow-hidden transition-all"
        >
          <span class="absolute -top-4 -right-4 text-[12rem] leading-none font-bold text-zinc-100 dark:text-zinc-900/40 -z-10 select-none transition-transform duration-700 group-hover:scale-110 group-hover:-rotate-3">01</span>
          
          <div class="flex flex-col h-full">
            <time datetime={scoredPosts[0].post.data.date.toISOString()} class="text-xs font-mono text-zinc-400 mb-6 block tracking-widest">
              {dayjs(scoredPosts[0].post.data.date).format('YYYY / MM / DD')}
            </time>
            <h3 class="font-noto text-3xl md:text-4xl font-bold text-zinc-900 dark:text-zinc-100 mb-8 leading-tight group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-colors">
              {scoredPosts[0].post.data.title}
            </h3>
             <div class="flex items-center text-xs font-bold uppercase tracking-[0.2em] text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-zinc-100 transition-colors mt-auto">
              <span>Read Post</span>
              <IconArrowRight class="ml-3 w-4 h-4 transition-transform duration-500 group-hover:translate-x-3" />
            </div>
          </div>
        </a>
      )}

      <div class="flex flex-col gap-16 md:gap-20 md:col-span-1">
        {scoredPosts.slice(1).map((item, index) => (
          <a 
            href={`/blog/${item.post.id}`}
            class="group transition-all"
          >
            <div class="flex items-center justify-between mb-6">
              <span class="text-xs font-mono text-zinc-400 tracking-tighter">/ 0{index + 2}</span>
              <IconArrowRight class="w-4 h-4 text-zinc-300 group-hover:text-zinc-900 dark:group-hover:text-zinc-100 -rotate-45 group-hover:rotate-0 transition-all duration-500" />
            </div>
            <h3 class="font-noto text-xl font-bold text-zinc-800 dark:text-zinc-200 leading-snug group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-colors line-clamp-3">
              {item.post.data.title}
            </h3>
          </a>
        ))}
      </div>
    </div>
  </aside>
)}
