---
import type { CollectionEntry } from 'astro:content';
import IconArrowLeft from '~icons/tabler/arrow-left';
import IconArrowRight from '~icons/tabler/arrow-right';

interface Props {
  prev: CollectionEntry<'blog'> | null;
  next: CollectionEntry<'blog'> | null;
}

const { prev, next } = Astro.props;

if (!prev && !next) return null;

const hasBoth = prev && next;
---

<nav class={`my-12 relative ${hasBoth ? 'grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24' : 'flex flex-col'}`}>
  {prev && (
    <a
      href={`/blog/${prev.id}`}
      class="flex flex-col items-start text-left group transition-all"
    >
      <span class="font-mono text-xs text-zinc-400 mb-6 tracking-[0.2em] uppercase">01 / Newer Post</span>
      <h3 class="font-noto text-2xl md:text-3xl font-bold text-zinc-900 dark:text-zinc-100 leading-tight group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-colors">
        {prev.data.title}
      </h3>
      <div class="mt-8 flex items-center text-xs font-bold uppercase tracking-widest text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-zinc-100 transition-colors">
        <IconArrowLeft class="mr-2 transition-transform duration-500 group-hover:-translate-x-3" />
        <span>Previous</span>
      </div>
    </a>
  )}

  {next && (
    <a
      href={`/blog/${next.id}`}
      class={`flex flex-col items-end text-right group transition-all ${hasBoth ? 'md:mt-24' : ''}`}
    >
      <span class="font-mono text-xs text-zinc-400 mb-6 tracking-[0.2em] uppercase">02 / Older Post</span>
      <h3 class="font-noto text-2xl md:text-3xl font-bold text-zinc-900 dark:text-zinc-100 leading-tight group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-colors">
        {next.data.title}
      </h3>
      <div class="mt-8 flex items-center text-xs font-bold uppercase tracking-widest text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-zinc-100 transition-colors">
        <span>Next</span>
        <IconArrowRight class="ml-2 transition-transform duration-500 group-hover:translate-x-3" />
      </div>
    </a>
  )}
</nav>
