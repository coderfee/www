---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = '页面未找到';
const description = '你访问的页面不存在或已经移动。';
---

<BaseLayout {title} {description} showTopNavigation={true} showBottomNavigation={true}>
  <section class="mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center px-4 py-24 text-center">
    <p class="text-sm font-medium text-zinc-500 dark:text-zinc-400">404</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight text-zinc-950 dark:text-zinc-50">页面未找到</h1>
    <p class="mt-4 text-base leading-7 text-zinc-600 dark:text-zinc-400">
      这个地址暂时没有内容，可以回到首页继续浏览。
    </p>
    <a
      href="/"
      class="mt-8 inline-flex h-11 items-center justify-center rounded-md bg-zinc-950 px-5 text-sm font-medium text-white transition-colors hover:bg-zinc-800 dark:bg-zinc-50 dark:text-zinc-950 dark:hover:bg-zinc-200"
    >
      返回首页
    </a>
  </section>
</BaseLayout>
