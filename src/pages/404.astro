---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = '页面未找到';
const description = '你访问的页面不存在或已经移动。';
---

<BaseLayout {title} {description} showTopNavigation={true} showBottomNavigation={true}>
  <section
    class="mx-auto flex min-h-[calc(100dvh-9rem)] max-w-4xl items-center justify-center px-4 py-16 pb-36 select-none sm:px-6 sm:py-24 sm:pb-28"
  >
    <span class="font-major flex flex-col text-7xl leading-none text-zinc-950 sm:block sm:text-9xl dark:text-zinc-50">
      <span>4</span>
      <span>0</span>
      <span>4</span>
    </span>
  </section>
</BaseLayout>
