---
import wereadStats from '@/data/weread-readdata.json';
import BaseLayout from '@/layouts/BaseLayout.astro';
import IconBooks from '~icons/tabler/books';

interface Book {
  title: string;
  author?: string;
  cover?: string;
  intro?: string;
  category?: string;
  publisher?: string;
  readTimeText: string;
}

interface Category {
  categoryTitle: string;
  readingCount: number;
  readingTime: number;
}

interface Author {
  name: string;
  count: number;
  readTime: string;
}

interface ReadDataSummary {
  readDays: number;
  totalReadTimeText: string;
  dayAverageReadTimeText: string;
  topBooks: Book[];
  stats?: Array<{
    stat: string;
    counts: string;
  }>;
  preferences?: {
    categoryWord?: string;
    timeWord?: string;
    categories?: Category[];
    authors?: Author[];
  };
}

const data = wereadStats.data as {
  weekly?: ReadDataSummary | null;
  monthly?: ReadDataSummary | null;
  annually?: ReadDataSummary | null;
  overall?: ReadDataSummary | null;
} | null;

const modeOptions = [
  { key: 'weekly', label: '本周' },
  { key: 'monthly', label: '本月' },
  { key: 'annually', label: '今年' },
  { key: 'overall', label: '累计' },
] as const;

const availableModes = modeOptions
  .map((mode) => ({
    ...mode,
    summary: data?.[mode.key],
  }))
  .filter((mode): mode is (typeof modeOptions)[number] & { summary: ReadDataSummary } => Boolean(mode.summary));

const defaultMode = availableModes.find((mode) => mode.key === 'annually') ?? availableModes[0];
const annually = data?.annually;
const updatedAt = new Date(wereadStats.updatedAt);
const updatedText = Number.isNaN(updatedAt.getTime())
  ? ''
  : `${updatedAt.getFullYear()}.${updatedAt.getMonth() + 1}.${updatedAt.getDate()}`;

const title = '阅读';
const description = '微信读书统计与近期阅读记录';
---

<BaseLayout title={title} description={description}>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-7 sm:py-14 pb-36 sm:pb-28">
    <header class="flex flex-col gap-4 sm:gap-5">
      <div class="flex items-center gap-3 text-[#38A8FF]">
        <IconBooks class="size-7" />
        <span class="text-sm font-medium">微信读书</span>
      </div>

      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">阅读</h1>
          <p class="mt-3 text-sm sm:text-base text-zinc-500 dark:text-zinc-400">
            今年读了 {annually?.totalReadTimeText ?? '0分钟'}，共 {annually?.readDays ?? 0} 天。
          </p>
        </div>
        {updatedText && <p class="text-xs text-zinc-400 dark:text-zinc-500">更新于 {updatedText}</p>}
      </div>

      {availableModes.length > 1 && (
        <div class="inline-grid grid-cols-4 w-full sm:inline-flex sm:w-fit rounded-full border border-zinc-100 dark:border-white/10 bg-zinc-50 dark:bg-white/3 p-1">
          {availableModes.map((mode) => (
            <button
              type="button"
              data-reading-tab={mode.key}
              aria-pressed={mode.key === defaultMode?.key ? 'true' : 'false'}
              class="rounded-full px-3 sm:px-4 py-2 text-sm font-medium text-zinc-500 transition-colors aria-pressed:bg-white aria-pressed:text-zinc-900 aria-pressed:shadow-sm dark:text-zinc-400 dark:aria-pressed:bg-white/10 dark:aria-pressed:text-zinc-50"
            >
              {mode.label}
            </button>
          ))}
        </div>
      )}
    </header>

    <div class="mt-8 sm:mt-12">
      {availableModes.map(({ key, label, summary }) => {
        const books = summary.topBooks?.slice(0, 7) ?? [];
        const primaryBook = books[0];
        const restBooks = books.slice(1);
        const categories = summary.preferences?.categories?.filter((category) => category.readingTime > 0).slice(0, 5) ?? [];
        const authors = summary.preferences?.authors?.slice(0, 5) ?? [];
        const stats = summary.stats ?? [];
        const hasAside =
          stats.length > 0 ||
          categories.length > 0 ||
          Boolean(summary.preferences?.categoryWord) ||
          authors.length > 0 ||
          Boolean(summary.preferences?.timeWord);

        return (
          <section
            data-reading-panel={key}
            class:list={['flex flex-col gap-7 sm:gap-10', key !== defaultMode?.key && 'hidden']}
          >
            {primaryBook && (
              <article class="grid gap-5 sm:grid-cols-[14rem_minmax(0,1fr)] sm:gap-10 sm:items-start">
                {primaryBook.cover && (
                  <div class="w-32 h-48 sm:w-56 sm:h-80 flex items-center justify-center mx-auto sm:mx-0">
                    <img
                      src={primaryBook.cover}
                      alt=""
                      loading="lazy"
                      class="max-w-full max-h-full rounded-lg object-contain"
                    />
                  </div>
                )}

                <div class="min-w-0 pt-1">
                  <p class="text-xs font-medium text-[#38A8FF]">{label}读得最多</p>
                  <h2 class="mt-3 text-2xl sm:text-4xl font-semibold leading-tight text-zinc-900 dark:text-zinc-50 break-words">
                    {primaryBook.title}
                  </h2>
                  {primaryBook.author && (
                    <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-400">{primaryBook.author}</p>
                  )}

                  {primaryBook.category && (
                    <p class="mt-4 text-xs text-zinc-400 dark:text-zinc-500">
                      {[primaryBook.category, primaryBook.publisher].filter(Boolean).join(' · ')}
                    </p>
                  )}

                  {primaryBook.intro && (
                    <p class="mt-5 hidden sm:block sm:line-clamp-5 text-sm leading-7 text-zinc-500 dark:text-zinc-400">
                      {primaryBook.intro.trim()}
                    </p>
                  )}
                </div>
              </article>
            )}

            <section class="grid lg:grid-cols-[minmax(0,1fr)_18rem] gap-7 sm:gap-8 lg:gap-12 items-start">
              <div class="min-w-0">
                {restBooks.length > 0 && (
                  <section>
                    <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-50">继续看的书</h2>
                    <div class="mt-4 divide-y divide-zinc-100 dark:divide-white/10">
                      {restBooks.map((book, index) => (
                        <article class="grid grid-cols-[1.25rem_3rem_minmax(0,1fr)] sm:flex sm:items-start gap-3 sm:gap-4 py-4">
                          <span class="pt-1 w-5 text-xs text-zinc-300 dark:text-zinc-600">{index + 2}</span>
                          {book.cover && (
                            <div class="w-12 h-16 shrink-0 flex items-center justify-center">
                              <img src={book.cover} alt="" loading="lazy" class="max-w-full max-h-full rounded object-contain" />
                            </div>
                          )}
                          <div class="min-w-0 sm:flex-1">
                            <h3 class="text-sm font-medium text-zinc-900 dark:text-zinc-50 truncate">{book.title}</h3>
                            <p class="mt-1 text-xs text-zinc-400 dark:text-zinc-500 truncate">
                              {[book.author, book.category].filter(Boolean).join(' · ') || '未知作者'}
                            </p>
                            <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400 sm:hidden">{book.readTimeText}</p>
                          </div>
                          <span class="hidden sm:block text-xs text-zinc-500 dark:text-zinc-400 shrink-0">{book.readTimeText}</span>
                        </article>
                      ))}
                    </div>
                  </section>
                )}
              </div>

              {hasAside && (
                <aside class="min-w-0 space-y-7 sm:space-y-8 border-t border-zinc-100 pt-7 dark:border-white/10 lg:sticky lg:top-24 lg:border-t-0 lg:pt-0">
                  {stats.length > 0 && (
                    <section>
                      <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-50">{label}概览</h2>
                      <div class="mt-4 space-y-4">
                        {stats.map((item) => (
                          <div class="flex items-baseline justify-between gap-4">
                            <span class="text-sm text-zinc-500 dark:text-zinc-400">{item.stat}</span>
                            <span class="text-base font-semibold text-zinc-900 dark:text-zinc-50 shrink-0">{item.counts}</span>
                          </div>
                        ))}
                      </div>
                    </section>
                  )}

                  {(categories.length > 0 || summary.preferences?.categoryWord) && (
                    <section>
                      <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-50">偏好</h2>
                      {categories.length > 0 && (
                        <div class="mt-4 flex flex-wrap gap-2">
                          {categories.map((category) => (
                            <span class="max-w-full rounded-full border border-zinc-100 dark:border-white/10 px-3 py-1.5 text-sm text-zinc-600 dark:text-zinc-300 truncate">
                              {category.categoryTitle} · {category.readingCount} 本
                            </span>
                          ))}
                        </div>
                      )}
                      {summary.preferences?.categoryWord && (
                        <p class="mt-4 text-sm text-zinc-500 dark:text-zinc-400">{summary.preferences.categoryWord}</p>
                      )}
                    </section>
                  )}

                  {(authors.length > 0 || summary.preferences?.timeWord) && (
                    <section>
                      <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-50">作者</h2>
                      {authors.length > 0 && (
                        <div class="mt-4 space-y-3">
                          {authors.map((author) => (
                            <div class="flex items-baseline justify-between gap-4">
                              <span class="text-sm text-zinc-600 dark:text-zinc-300 truncate">{author.name}</span>
                              <span class="text-xs text-zinc-400 dark:text-zinc-500 shrink-0">
                                {author.count} 本 · {author.readTime}
                              </span>
                            </div>
                          ))}
                        </div>
                      )}
                      {summary.preferences?.timeWord && (
                        <p class="mt-4 text-sm text-zinc-500 dark:text-zinc-400">{summary.preferences.timeWord}</p>
                      )}
                    </section>
                  )}
                </aside>
              )}
            </section>
          </section>
        );
      })}
    </div>
  </main>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-reading-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-reading-panel]');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const mode = tab.dataset.readingTab;

      tabs.forEach((item) => {
        item.setAttribute('aria-pressed', String(item === tab));
      });

      panels.forEach((panel) => {
        panel.classList.toggle('hidden', panel.dataset.readingPanel !== mode);
      });
    });
  });
</script>
